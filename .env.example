# ── OpenAI ─────────────────────────────────────────────────────────────────
# Required — your OpenAI secret key
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional — model to use (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# Optional — max tokens per generation request (default: 4096)
OPENAI_MAX_TOKENS=4096

# ── API Security ────────────────────────────────────────────────────────────
# Shared secret between the browser client and the Next.js API routes.
# Set both to the same random string (e.g. `openssl rand -hex 32`).
# Leave blank in local dev to skip validation.

# Server-side validation (never exposed to the browser)
API_SECRET_KEY=your-random-secret-here

# Client-side (browser) — must match API_SECRET_KEY
NEXT_PUBLIC_API_SECRET=your-random-secret-here

# ── API Documentation (Swagger) ─────────────────────────────────────────────
# Secret for protected /docs?key=... and GET /api/openapi?key=...
# Generate with: openssl rand -hex 32
DOCS_SECRET_KEY=your-docs-secret-here
